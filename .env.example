# Environment variables for Smart Expense Analyzer
# Copy to .env and fill in values

# PostgreSQL
DB_PASSWORD=change-me-strong-password

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-256-bits-long

# Anthropic Claude API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Storage path (absolute path on host)
STORAGE_PATH=./uploads

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:4200

# Mail (optional, for spending alerts)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@expensetracker.com
